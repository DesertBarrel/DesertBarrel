# Copy to `.env.deploy` (DO NOT COMMIT)

# Required: funded deployer wallet private key (0x... hex, no quotes)
PRIVATE_KEY=

# Required: JSON-RPC URL for the network you deploy to
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# Optional: used by `hardhat verify` on BaseScan
BASESCAN_API_KEY=

# Token parameters
TOKEN_NAME=Desert Barrel
TOKEN_SYMBOL=DBRL
# Human-readable supply (18 decimals). Example: 1_000_000_000 = 1 billion tokens.
TOKEN_SUPPLY_HUMAN=1000000000
